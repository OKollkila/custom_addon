<odoo>
    <data>
        <record model="ir.ui.view" id="view_local_users_form">
            <field name="name">local.users.form</field>
            <field name="model">local_users_admin.user</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_reset_password" string="Send Reset Password E-mail" type="object" class="btn-warning"/>
                    </header>
                    <sheet string="local_users_admin.user">
                        <group col="2">
                            <field name="name"/>
                            <field name="email"/>
                            <field name="selected_group_ids" widget="many2many_tags"/>
                            <field name="all_group_ids" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>