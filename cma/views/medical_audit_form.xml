<odoo>
    <data>
        <record id="view_medical_audit_form" model="ir.ui.view">
            <field name="name">medical_audit.form</field>
            <field name="model">clinizone.medical_audit</field>
            <field name="arch" type="xml">
                <form string="Medical Audit">
                    <sheet>
                        <notebook>
                            <page string="Details">
                                <group>
                                    <field name="visit_date"/>
                                    <field name="prime_care_branch_id"/>
                                    <field name="patient_name"/>
                                    <field name="mobile_no"/>
                                    <field name="doctor_name"/>
                                    <field name="chief_complaint"/>
                                    <field name="medical_history"/>
                                    <field name="doctor_note"/>
                                    <field name="treatment_plan"/>
                                    <field name="significant_sign"/>
                                    <field name="diagnosis"/>
                                    <field name="mrno"/>
                                    <field name="age"/>
                                    <field name="department"/>
                                    <field name="speciality"/>
                                    <field name="services"/>
                                    <field name="risk_factor"/>
                                    <field name="chief_complaint1"/>
                                    <field name="comorbidities"/>
                                    <field name="diagnosis2"/>
                                    <field name="diagnosis_accuracy"/>
                                    <field name="chief_complaint2"/>
                                    <field name="treatment_plan2"/>
                                    <field name="allergy"/>
                                    <field name="clinical_examination"/>
                                    <field name="history"/>
                                    <field name="services_requested"/>
                                    <field name="services_done"/>
                                    <field name="services_required"/>
                                    <field name="recommendation_for_clinical_variance"/>
                                    <field name="recommendation_for_leakage"/>
                                    <field name="recommendation_for_comprehensiveness"/>
                                    <field name="recommendation_for_ttp"/>
                                    <field name="recommendation_for_wellness"/>
                                    <field name="next_visit_date"/>
                                    <field name="long_term_plan"/>
                                    <field name="lttp_date"/>
                                    <field name="medical_audit_recommendations"/>
                                    <field name="lead_id"/>
                                    <field name="lttp_lead_id"/>
                                </group>
                            </page>
                            <page string="History">
                                <div class="oe_chatter">
                                    <field name="message_ids"/>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>