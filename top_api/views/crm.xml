<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit CRM Lead Form View to Add Employee Field -->
        <record id="crm_lead_view_form_inherit_employee" model="ir.ui.view">
            <field name="name">crm.lead.form.employee</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="employee_id" options="{'no_create': True, 'no_edit': True}"/>
                </xpath>
            </field>
        </record>
        <record id="crm_lead_view_form_services" model="ir.ui.view">
            <field name="name">crm.lead.form.employee</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='service_id']" position="after">
                    <field name="service_detailes" options="{'no_create': True, 'no_edit': True}"/>
                </xpath>
            </field>
        </record>
        <!-- Inherit CRM Lead Tree View to Show Employee Field -->
        <record id="crm_lead_view_tree_inherit_employee" model="ir.ui.view">
            <field name="name">crm.lead.tree.employee</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="employee_id" optional="hide"/>
                </xpath>
            </field>
        </record>

        <!-- Simple Search View with Employee Field -->
        <record id="crm_lead_view_search_inherit_employee" model="ir.ui.view">
            <field name="name">crm.lead.search.employee</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
            <field name="arch" type="xml">
                <!-- Add Employee to search fields -->
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="employee_id" string="Employee"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
