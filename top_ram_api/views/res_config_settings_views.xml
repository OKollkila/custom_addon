<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Inherit Helpdesk Settings -->
    <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.ram.api</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="helpdesk.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add RAM API configuration section -->
            <xpath expr="//div[@id='helpdesk_settings']" position="after">
                <h2>RAM Prime Care API Integration</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label string="RAM API Configuration" for="ram_api_bearer_token"/>
                            <div class="text-muted">
                                Configure Bearer token and endpoint for RAM Prime Care API integration
                            </div>
                            <div class="content-group mt16">
                                <div class="row">
                                    <label string="Bearer Token" for="ram_api_bearer_token" class="col-lg-3 o_light_label"/>
                                    <field name="ram_api_bearer_token" password="True" placeholder="Enter Bearer Token" class="oe_inline"/>
                                </div>
                                <div class="row mt8">
                                    <label string="API Endpoint" for="ram_api_endpoint" class="col-lg-3 o_light_label"/>
                                    <field name="ram_api_endpoint" placeholder="https://ramprimecare.com/..." class="oe_inline"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>

