<odoo>
    <record id="group_helpdesk_refund_processor" model="res.groups">
        <field name="name">Refund Processor (Level 4 Only)</field>
        <field name="category_id" ref="base.module_category_services_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_helpdesk_workflow_allow_downgrade" model="res.groups">
        <field name="name">Allow workflow level downgrade</field>
        <field name="category_id" ref="base.module_category_services_helpdesk"/>
        <field name="comment">Users in this group may set a ticket workflow level to a lower sequence (e.g. Level 4 to Level 3). Others cannot downgrade.</field>
        <field name="implied_ids" eval="[(4, ref('helpdesk.group_helpdesk_user'))]"/>
    </record>
</odoo>