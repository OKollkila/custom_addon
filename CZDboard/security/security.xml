<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_cz_dashboard" model="ir.module.category">
            <field name="name">CliniZone Dashboard</field>
            <field name="description">Helps you control who can see the CRM Dashboard</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_cz_dashboard_viewer" model="res.groups">
            <field name="name">View Dashboard</field>
            <field name="category_id" ref="module_category_cz_dashboard"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Users in this group can access the CliniZone Dashboard.</field>
        </record>
    </data>
</odoo>