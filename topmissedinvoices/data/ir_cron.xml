<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job for processing rejected services -->
        <record id="ir_cron_tomissedinvoices" model="ir.cron">
            <field name="name">Top Missed Invoices - Process Rejected Services</field>
            <field name="model_id" ref="model_top_missed_invoice"/>
            <field name="state">code</field>
            <field name="code">model.cron_process_rejected_services()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
