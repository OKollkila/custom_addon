<odoo>
    <!-- ========================= -->
    <!-- First Approver Group -->
    <!-- ========================= -->
    <record id="group_timeoff_first_approver" model="res.groups">
        <field name="name">Time Off First Approver</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <!-- Record Rule: First Approver يشوف طلبات موظفينه في حالة To Approve -->
    <record id="timeoff_rule_first_approver" model="ir.rule">
        <field name="name">Time Off First Approver - To Approve</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="groups" eval="[(4, ref('timeoff_first_approver.group_timeoff_first_approver'))]"/>
        <field name="domain_force">[
            ('employee_id.parent_id.user_id','=',user.id),
            ('state','=','confirm')
        ]</field>
    </record>

    <!-- ========================= -->
    <!-- Second Approver Group -->
    <!-- ========================= -->
    <record id="group_timeoff_second_approver" model="res.groups">
        <field name="name">Time Off Second Approver</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <!-- Record Rule: Second Approver يشوف طلبات موظفينه في حالة Second Approval -->
    <record id="timeoff_rule_second_approver" model="ir.rule">
        <field name="name">Time Off Second Approver - Second Approval</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="groups" eval="[(4, ref('timeoff_first_approver.group_timeoff_second_approver'))]"/>
        <field name="domain_force">[
            ('employee_id.parent_id.user_id','=',user.id),
            ('state','=','validate1')
        ]</field>
    </record>
</odoo>
