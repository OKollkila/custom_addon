<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Biometric Attendance Devices Views -->
    <record id="biometric_attendance_devices_view_list" model="ir.ui.view">
        <field name="name">biometric.attendance.devices.list</field>
        <field name="model">biometric.attendance.devices</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Biometric Devices">
                <field name="biometric_attendance_id"/>
                <field name="device_id"/>
            </list>
        </field>
    </record>

    <record id="biometric_attendance_devices_view_form" model="ir.ui.view">
        <field name="name">biometric.attendance.devices.form</field>
        <field name="model">biometric.attendance.devices</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Biometric Device">
                <sheet>
                    <group>
                        <field name="employee_id" readonly="1"/>
                        <field name="biometric_attendance_id"/>
                        <field name="device_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Employee Inherited View -->
    <record id="hr_employee_view_attendance_inherit" model="ir.ui.view">
        <field name="name">hr.employee.view.attendance.inherit</field>
        <field name="model">hr.employee</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="after">
                <page string="Biometric Devices">
                    <field name="biometric_device_ids" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
