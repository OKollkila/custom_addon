<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Inherit company form view to add assigned employees field -->
        <record id="view_company_form_inherit_assigned_employees" model="ir.ui.view">
            <field name="name">res.company.form.inherit.assigned.employees</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Employee Management" name="employee_management">
                        <group string="Assigned Employees">
                            <field name="assigned_employee_ids" 
                                   widget="many2many_tags" 
                                   options="{'color_field': 'color', 'no_create_edit': True}"
                                   nolabel="1"/>
                        </group>
                        <separator/>
                        <group string="Employee Assignment Information">
                            <field name="assigned_employees_count" string="Total Assigned Employees" readonly="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Optional: Add assigned employees field to company tree view for quick reference -->
        <record id="view_company_tree_inherit_assigned_employees" model="ir.ui.view">
            <field name="name">res.company.tree.inherit.assigned.employees</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="assigned_employee_ids" widget="many2many_tags" optional="hide"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
