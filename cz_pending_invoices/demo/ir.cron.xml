<odoo>
    <data>
        <record model="ir.cron" id="cron_pull_pending_invoices">
            <field name="name">Pull Missed Invoices</field>
            <field name="model_id" ref="model_cz_prime_care_pending_invoice_poll"/>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="active">0</field>
            <field name="code">model.prime_care_poll_yesterday()</field>
        </record>
    </data>
    <data>
        <record model="ir.cron" id="cron_create_leads">
            <field name="name">Create Leads From Missed Invoices</field>
            <field name="model_id" ref="model_cz_pending_invoice"/>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="active">0</field>
            <field name="code">model.create_leads_for_pending_invoices_from_yesterday()</field>
        </record>
    </data>
</odoo>
