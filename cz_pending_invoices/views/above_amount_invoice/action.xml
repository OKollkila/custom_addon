<odoo>
    <data>
        <!-- Actions (defined first to avoid reference errors) -->
        <record id="action_above_amount_invoice" model="ir.actions.act_window">
            <field name="name">Invoices Above Amount</field>
            <field name="res_model">cz.above_amount_invoice</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_today': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No invoices found
                </p>
                <p>
                    Invoices above amount will appear here after the scheduled action runs.
                </p>
            </field>
        </record>
    </data>
</odoo>

