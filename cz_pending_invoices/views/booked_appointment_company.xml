<odoo>
    <data>
        <record id="form_company_booked_appointment" model="ir.ui.view">
            <field name="name">Booked Appointment Settings</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="priority" eval="12"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='general_info']" position="after">
                    <page string="Booked Appointments" name="booked_appointments">
                        <group>
                            <group>
                                <field name="booked_appointment_url"/>
                            </group>
                            <group>
                                <field name="booked_appointment_token"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

