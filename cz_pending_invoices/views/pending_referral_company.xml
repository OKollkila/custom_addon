<odoo>
    <data>
        <record id="form_company_pending_referral" model="ir.ui.view">
            <field name="name">Pending Referral Settings</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="priority" eval="10"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='general_info']" position="after">
                    <page string="Pending Referrals" name="pending_referrals">
                        <group>
                            <group>
                                <field name="pending_referral_url"/>
                            </group>
                            <group>
                                <field name="pending_referral_token"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

