<odoo>
    <data>
        <record id="form_company_dna_appointment" model="ir.ui.view">
            <field name="name">DNA Appointment Settings</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="priority" eval="11"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='general_info']" position="after">
                    <page string="DNA Appointments" name="dna_appointments">
                        <group>
                            <group>
                                <field name="dna_appointment_url"/>
                            </group>
                            <group>
                                <field name="dna_appointment_token"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

