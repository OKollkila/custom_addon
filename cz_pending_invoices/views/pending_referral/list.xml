<odoo>
    <data>
        <record id="view_pending_referral_list" model="ir.ui.view">
            <field name="name">Pending Referral List</field>
            <field name="model">cz.pending_referral</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Pending and Rejected Referrals">
                    <field name="date"/>
                    <field name="status"/>
                    <field name="patient_name"/>
                    <field name="mrno"/>
                    <field name="from_doctor"/>
                    <field name="to_doctor"/>
                    <field name="visit_status"/>
                    <field name="requested_date"/>
                    <field name="branch"/>
                    <field name="department"/>
                    <field name="speciality"/>
                    <field name="reason"/>
                    <field name="rejection_reason"/>
                </list>
            </field>
        </record>

        <record id="view_pending_referral_form" model="ir.ui.view">
            <field name="name">Pending Referral Form</field>
            <field name="model">cz.pending_referral</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Pending Referral">
                    <header>
                        <button name="action_create_leads" string="Create Lead" type="object" class="btn-primary" invisible="lead_id != False"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Patient Information">
                                <field name="patient_name"/>
                                <field name="mrno"/>
                                <field name="patient_id"/>
                            </group>
                            <group string="Status">
                                <field name="visit_status"/>
                                <field name="date"/>
                                <field name="lead_id" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <group string="Doctors">
                                <field name="from_doctor"/>
                                <field name="to_doctor"/>
                                <field name="from_consultant_id"/>
                                <field name="to_consultant_id"/>
                                <field name="consultant_id"/>
                            </group>
                            <group string="Location">
                                <field name="branch"/>
                                <field name="branch_id"/>
                                <field name="department"/>
                                <field name="department_id"/>
                                <field name="speciality"/>
                            </group>
                        </group>
                        <group>
                            <group string="Dates">
                                <field name="requested_date"/>
                                <field name="visit_date"/>
                            </group>
                            <group string="Service &amp; Financial">
                                <field name="service_name"/>
                                <field name="priority"/>
                                <field name="amount"/>
                                <field name="net_amt"/>
                                <field name="invoice_id"/>
                            </group>
                        </group>
                        <group>
                            <group string="Other Details">
                                <field name="visit_no"/>
                                <field name="encounter_id"/>
                                <field name="action"/>
                                <field name="branch_id_code"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Reason" name="reason">
                                <field name="reason" nolabel="1"/>
                            </page>
                            <page string="Rejection Reason" name="rejection_reason" invisible="rejection_reason == False">
                                <field name="rejection_reason" nolabel="1"/>
                            </page>
                            <page string="Full Description" name="description">
                                <field name="description" nolabel="1" readonly="1" widget="html"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_pending_referral_search" model="ir.ui.view">
            <field name="name">Pending Referral Search</field>
            <field name="model">cz.pending_referral</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="Search Referrals">
                    <field name="patient_name"/>
                    <field name="mrno"/>
                    <field name="from_doctor"/>
                    <field name="to_doctor"/>
                    <field name="branch"/>
                    <field name="department"/>
                    <field name="status"/>
                    <filter string="Pending" name="pending" domain="[('status', '=', 'Pending')]"/>
                    <filter string="Rejected" name="rejected" domain="[('status', '=', 'Rejected')]"/>
                    <filter string="Today" name="today" 
                            domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter string="This Week" name="week" 
                            domain="[('date', '&gt;=', (context_today()-datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    <filter string="No Lead" name="no_lead" domain="[('lead_id', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Branch" name="group_branch" context="{'group_by': 'branch'}"/>
                        <filter string="Department" name="group_department" context="{'group_by': 'department'}"/>
                        <filter string="From Doctor" name="group_from_doctor" context="{'group_by': 'from_doctor'}"/>
                        <filter string="To Doctor" name="group_to_doctor" context="{'group_by': 'to_doctor'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>

