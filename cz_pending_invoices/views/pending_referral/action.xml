<odoo>
    <data>
        <!-- Actions (defined first to avoid reference errors) -->
        <record id="action_pending_referral" model="ir.actions.act_window">
            <field name="name">Pending Referrals</field>
            <field name="res_model">cz.pending_referral</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_pending': 1, 'search_default_today': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No pending referrals found
                </p>
                <p>
                    Pending and rejected referrals will appear here after the scheduled action runs.
                </p>
            </field>
        </record>
    </data>
</odoo>

