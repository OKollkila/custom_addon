<odoo>
    <data>
        <!-- Actions (defined first to avoid reference errors) -->
        <record id="action_dna_appointment" model="ir.actions.act_window">
            <field name="name">DNA Appointments</field>
            <field name="res_model">cz.dna_appointment</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_today': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No DNA appointments found
                </p>
                <p>
                    DNA (Did Not Attend) appointments will appear here after the scheduled action runs.
                </p>
            </field>
        </record>
    </data>
</odoo>

