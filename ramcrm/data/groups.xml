<odoo>
    <record model="ir.module.category" id="module_management">
        <field name="name">CliniZone</field>
    </record>

    <record model="res.groups" id="group_leads_analysis_report">
        <field name="name">Leads Analysis Report</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_detailed_leads_analysis_report">
        <field name="name">Detailed Leads Analysis Report</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_create_branch">
        <field name="name">Create Branches</field>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_create_lead_source">
        <field name="name">Create Lead Sources</field>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_agent">
        <field name="name">Agent</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_external_user">
        <field name="name">External User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
        <field name="menu_access" eval="[(4, ref('crm.crm_menu_root'))]"/>
    </record>

    <record model="res.groups" id="group_team_manager">
        <field name="name">Team Manager</field>
        <field name="implied_ids" eval="[(4, ref('ramcrm.group_agent'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_helpdesk_reports_viewer">
        <field name="name">Helpdesk Reports Viewer</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_helpdesk_archive_tickets">
        <field name="name">Helpdesk: Archive Tickets</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_helpdesk_change_type">
        <field name="name">Helpdesk: Change Ticket Type</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>

    <record model="res.groups" id="group_admin">
        <field name="name">Administrator</field>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('ramcrm.group_leads_analysis_report')), (4, ref('ramcrm.group_detailed_leads_analysis_report')), (4, ref('ramcrm.group_agent')), (4, ref('ramcrm.group_team_manager'))]"/>
        <field name="category_id" ref="ramcrm.module_management"/>
    </record>
</odoo>