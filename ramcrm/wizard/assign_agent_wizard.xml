<odoo>
    <data>
        <record model="ir.ui.view" id="ramcrm_assign_agent_wizard_form">
            <field name="name">Assign Agent</field>
            <field name="model">ramcrm.assign_agent_wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet string="ramcrm.assign_agent_wizard">
                        <group col="2">
                            <field name="agent_id"/>
                            <field name="activity_type_id"/>
                            <field name="date_deadline"/>
                        </group>
                        <footer>
                            <button name="action_do" string="Assign Agent" type="object" class="btn-danger"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_assign_agent_wizard">
            <field name="name">Assign Agent</field>
            <field name="res_model">ramcrm.assign_agent_wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>