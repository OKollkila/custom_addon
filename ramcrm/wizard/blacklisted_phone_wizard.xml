<odoo>
    <data>
        <record model="ir.ui.view" id="ramcrm_blacklisted_phone_wizard_form">
            <field name="name">Assign Agent</field>
            <field name="model">ramcrm.blacklisted_phone_wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet string="ramcrm.blacklisted_phone_wizard">
                        <group col="2">
                            <field name="blacklisted_reason"/>
                        </group>
                        <footer>
                            <button name="action_do" string="Add to Blacklisted Phones" type="object" class="btn-danger"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_blacklisted_wizard">
            <field name="name">Add to Blacklisted Phones</field>
            <field name="res_model">ramcrm.blacklisted_phone_wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="ramcrm_blacklisted_phone_wizard_form"/>
        </record>
    </data>
</odoo>