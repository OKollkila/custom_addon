<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <template id="template_stats_report">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div>
                            <h2>
                                <strong>Detailed Leads Analysis</strong>
                            </h2>
                        </div>
                        <div>
                            <table style="margin: 15px;">
                                <tr>
                                    <td style="width: 200px; font-weight:bold; font-size:14px">Start Date</td>
                                    <td style="width: 250px;" class="text-left"><span t-esc="from_date"/></td>
                                </tr>
                                <tr>
                                    <td style="width: 200px; font-weight:bold; font-size:14px">End Date</td>
                                    <td style="width: 250px;" class="text-left"><span t-esc="to_date"/></td>
                                </tr>
                            </table>
                        </div>
                        <div>
                            <p style="font-weight:bold; font-size: 20px;"><u>City / Lead Source</u></p>
                            <table class="table table-bordered" style="font-size: 11px; text-align: center;">
                                <thead>
                                    <tr style="background: #cccccc;">
                                        <td rowspan="2">City</td>
                                        <t t-foreach="lead_sources" t-as="s">
                                            <td colspan="3"><span t-esc="s"/></td>
                                        </t>
                                        <td rowspan="2">Total</td>
                                    </tr>
                                    <tr style="background: #cccccc;">
                                        <t t-foreach="lead_sources" t-as="s">
                                            <td>T</td>
                                            <td>B</td>
                                            <td>%</td>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="cities" t-as="c">
                                        <tr>
                                            <td style="background: #cccccc;"><span t-esc="c"/></td>
                                            <t t-foreach="lead_sources" t-as="s">
                                                <td t-if="c in details and s in details[c]">
                                                    <t t-esc="details[c][s]['total']"/>
                                                </td>
                                                <td t-else="">  </td>
                                                <td t-if="c in details and s in details[c]">
                                                    <t t-esc="details[c][s]['booked']"/>
                                                </td>
                                                <td t-else="">  </td>
                                                <td t-if="c in details and s in details[c]">
                                                    <t t-esc="details[c][s]['cr']"/>
                                                </td>
                                                <td t-else="">  </td>
                                            </t>
                                            <td style="background: #eeeeee; font-weight: bold;"><span t-esc="row_sums[c]"/></td>
                                        </tr>
                                    </t>
                                    <tr style="font-weight:bold;">
                                        <td style="background: #cccccc;">Total</td>
                                        <t t-foreach="lead_sources" t-as="s">
                                            <td colspan="3" style="background: #eeeeee;"><span t-esc="column_sums[s]"/></td>
                                        </t>
                                        <td style="background: #eeeeee; font-weight: bold;" ><span t-esc="total_sum"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div>
                            <p style="font-weight:bold; font-size: 20px;"><u>Touched / Booked</u></p>
                            <table class="table table-bordered">
                                <thead>
                                    <tr style="font-size: 12px; height:20px; background: #cccccc">
                                        <td>State</td>
                                        <td>Total Leads</td>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="Stages" t-as="s">
                                        <tr>
                                            <td><span t-esc="s['stage']"/></td>
                                            <td><span t-esc="s['count']"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <div>
                            <p style="font-weight:bold; font-size: 20px;"><u>Detailed States</u></p>
                            <table class="table table-bordered">
                                <thead>
                                    <tr style="font-size: 11px; height:15px; background: #cccccc">
                                        <td>State</td>
                                        <td>Total Leads</td>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="detailed_stages" t-as="s">
                                        <tr>
                                            <td><span t-esc="s['stage']"/></td>
                                            <td><span t-esc="s['count']"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
    </template>
</odoo>