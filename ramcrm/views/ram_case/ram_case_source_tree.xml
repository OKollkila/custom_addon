<odoo>
    <data>
        <record id="view_ram_case_source_tree" model="ir.ui.view">
            <field name="name">ram_case_source.tree</field>
            <field name="model">clinizone.ram_case_source</field>
            <field name="arch" type="xml">
                <list string="Case Source" editable="top">
                    <field name="name"/>
                    <field name="created_by_customer"/>
                </list>
            </field>
        </record>

        <record id="action_case_source" model="ir.actions.act_window">
            <field name="name">Case Sources</field>
            <field name="res_model">clinizone.ram_case_source</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_ram_case_source_tree"/>
        </record>

    </data>
</odoo>