<odoo>
    <data>
        <record id="view_branch_tree" model="ir.ui.view">
            <field name="name">branch.tree</field>
            <field name="model">clinizone.branch</field>
            <field name="arch" type="xml">
                <list string="Branches" editable="top">
                    <field name="id"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="city_id"/>
                    <field name="company_id"/>
                    <field name="helpdesk_team_id"/>
                    <field name="medical_director_team_id"/>
                    <field name="can_be_selected"/>
                </list>
            </field>
        </record>
    </data>
</odoo>