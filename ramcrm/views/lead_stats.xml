<odoo>
    <data>
        <record id="lead_statistic_pivot" model="ir.ui.view">
            <field name="name">lead.statistic.pivot</field>
            <field name="model">crm.lead</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <pivot string="Leads Statistic" sample="1" disable_linking="True">
                    <field name="create_date" type="row"/>
                    <field name="business_category_id" type="col"/>
                    <field name="stage2" type="col"/>
                </pivot>
            </field>
        </record>

        <record id="action_lead_pivot" model="ir.actions.act_window">
            <field name="name">Stats</field>
            <field name="res_model">crm.lead</field>
            <field name="view_mode">pivot</field>
            <field name="view_id" ref="lead_statistic_pivot"/>
            <field name="domain">[('stage2', '!=', False), ('source_id', '!=', None)]</field>
        </record>

<!--        <menuitem id="menu_lead_statistic" name="Stats Pivot" parent="menu_statistics" action="action_lead_pivot" groups="ramcrm.group_stats_user" sequence="1"/>-->

    </data>
</odoo>