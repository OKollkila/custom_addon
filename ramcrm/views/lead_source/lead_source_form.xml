<odoo>
    <data>
        <record id="view_lead_source_form" model="ir.ui.view">
            <field name="name">lead_source.form</field>
            <field name="model">clinizone.lead_source</field>
            <field name="arch" type="xml">
                <form string="Lead Source">
                    <sheet>
                        <notebook>
                            <page string="Details">
                                <group>
                                    <field name="name"/>
                                    <field name="level_1_id"/>
                                    <field name="level_2_id"/>
                                    <field name="can_be_selected"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>