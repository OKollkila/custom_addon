<odoo>
    <data>
        <record id="view_lead_graph" model="ir.ui.view">
            <field name="name">lead.graph</field>
            <field name="model">crm.lead</field>
            <field name="arch" type="xml">
                <graph string="Analysis" sample="1">
                    <field name="stage_id"/>
                    <field name="created_date" interval="month"/>
                </graph>
            </field>
        </record>
    </data>
</odoo>