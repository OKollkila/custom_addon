<odoo>
    <record id="helpdesk_ticket_report_viewer" model="ir.rule">
        <field name="name">helpdesk_ticket_report_viewer</field>
        <field name="model_id" ref="helpdesk.model_helpdesk_ticket_report_analysis"/>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('ramcrm.group_helpdesk_reports_viewer'))]"/>
    </record>

    <record id="helpdesk_ticket_creator" model="ir.rule">
        <field name="name">helpdesk_ticket_creator</field>
        <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('create_uid', 'in', [user.id, False])]</field>
        <field name="groups" eval="[(4, ref('helpdesk.group_helpdesk_user'))]"/>
    </record>
</odoo>