<odoo>
    <record id="rule_leaders_see_all" model="ir.rule">
        <field name="name">Leaders see all</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="perm_create" eval="False" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_unlink" eval="False"/>
        <field name="groups" eval="[(4, ref('ramcrm.group_team_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

<!--    <delete model="ir.rule" id="crm.crm_rule_personal_lead"/>-->

    <record id="crm_rule_personal_lead" model="ir.rule">
        <field name="name">Own or Assigned Leads</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="perm_create" eval="False" />
        <field name="domain_force">['|', ('create_uid', '=', user.id), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman')), (4, ref('base.group_portal'))]"/>
    </record>

    <record id="crm_rule_no_access_by_default" model="ir.rule">
        <field name="name">No access by default to internal users</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="perm_create" eval="False" />
        <field name="domain_force">[(0,'=',1)]</field>
        <field name="groups" eval="[(6, 0, [ref('base.group_user'), ref('base.group_portal'), ref('base.group_public')])]"/>
    </record>

</odoo>